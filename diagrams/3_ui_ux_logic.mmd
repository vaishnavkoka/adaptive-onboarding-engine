    style Step5 fill:#ffa726
    style Processing fill:#ffb74d
    style Results fill:#90caf9
    style Card1 fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    style Card2 fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    style Card3 fill:#e0f2f1,stroke:#009688,stroke-width:2px
    style Excellent fill:#c8e6c9
    style Strong fill:#fff9c4
    style Moderate fill:#ffe0b2
    style Entry fill:#ffccbc
    style Early fill:#f8bbd0
    style Display fill:#80deea
    style Card1 fill:#a5d6a7
    style Card2 fill:#a5d6a7
    style Card3 fill:#a5d6a7
    style Card4 fill:#a5d6a7
    style Actions fill:#ffccbc
