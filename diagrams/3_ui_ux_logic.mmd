graph TD
    Start["🚀 User Arrives<br/>at Application"]
    
    Start --> Step1["📋 Step 1: Upload Resume<br/>Choose PDF/DOCX/TXT"]
    
    Step1 --> Step1a{Resume<br/>Uploaded?}
    Step1a -->|No| Step1
    Step1a -->|Yes| Step2
    
    Step2["📋 Step 2: Upload Job Description<br/>Paste or Upload File"]
    
    Step2 --> Step2a{Job Description<br/>Provided?}
    Step2a -->|No| Step2
    Step2a -->|Yes| Step3
    
    Step3["🎯 Step 3: Select Job Category<br/>Choose from 24 Categories"]
    
    Step3 --> Step4["🌐 Step 4: Choose Extraction Mode<br/>Fast Keyword or LLM (Optional)"]
    
    Step4 --> Step5["🔘 Click Analyze Skills<br/>Start Processing"]
    
    Step5 --> Processing["⏳ Processing...<br/>Extracting & Matching Skills"]
    
    Processing --> Results["✅ Results Ready!"]
    
    Results --> Display["📊 Dashboard Display"]
    
    Display --> Card1["📈 Match Score Card<br/>0-100% Score"]
    Display --> Card2["📋 Score Breakdown<br/>Transparent Calculation"]
    Display --> Card3["🎨 Score Interpretation<br/>Color-Coded 🟢🟡🟠🔴⚠️"]
    Display --> Card4["📍 Skills Gap Card<br/>Missing Skills List"]
    Display --> Card5["🎓 Learning Pathway<br/>Risk-Ranked Tasks"]
    Display --> Card6["🧠 Reasoning Trace<br/>Decision Logic"]
    
    Card1 --> ScoreBreak["📊 Show 4 Factors<br/>1. Base % Match<br/>2. Proficiency Bonus<br/>3. Extra Skills<br/>4. Final Score"]
    Card2 --> ScoreBreak
    ScoreBreak --> Card3
    
    Card3 --> ScoreInterpret{Score<br/>Range?}
    ScoreInterpret -->|80-100| Excellent["🟢 Excellent Match<br/>Minor learning needed"]
    ScoreInterpret -->|60-79| Strong["🟡 Strong Match<br/>Some development"]
    ScoreInterpret -->|40-59| Moderate["🟠 Moderate Match<br/>Structured learning"]
    ScoreInterpret -->|20-39| Entry["🔴 Entry-Level<br/>Comprehensive training"]
    ScoreInterpret -->|<20| Early["⚠️ Early Career<br/>Dedicated learning"]
    
    Excellent --> Actions["⚙️ User Actions"]
    Strong --> Actions
    Moderate --> Actions
    Entry --> Actions
    Early --> Actions
    
    Card4 --> Actions
    Card5 --> Actions
    Card6 --> Actions
    
    Actions --> Act1["📥 Download CSV<br/>Export All Results"]
    Actions --> Act2["📋 Copy Pathway<br/>Share with Team"]
    Actions --> Act3["🔄 Analyze New<br/>Start Over"]
    
    Act1 --> End["✨ Session Complete"]
    Act2 --> End
    Act3 --> Step1
    
    style Start fill:#81c784
    style Step1 fill:#64b5f6
    style Step2 fill:#64b5f6
    style Step3 fill:#64b5f6
